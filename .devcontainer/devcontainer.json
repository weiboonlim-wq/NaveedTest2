{
    "name": "Lorry Scheduler V2 (Streamlit)",
    "image": "mcr.microsoft.com/devcontainers/python:3.12",
    "postCreateCommand": "pip install -r requirements.txt",
    "customizations": {
        "codespaces": {
            "openFiles": ["app.py", "static/index.html"]
        }
    },
    "forwardPorts": [8501]
}
